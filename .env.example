# GitHub App > General > App ID
GITHUB_APP_ID=

# GitHub App > General > Client ID
GITHUB_APP_CLIENT_ID=

# GitHub App > General > Client secrets > Generate a new client secret
GITHUB_APP_CLIENT_SECRET=

# GitHub App > General > Private keys > Generate a private key
# Paste the downloaded .pem content.
# Vercel: do not include wrapping quotes. Real newlines, \n-escaped text, or base64-encoded PEM all work.
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Optional. Leave empty unless you want to pin one installation manually.
GITHUB_APP_INSTALLATION_ID=

# Content repository. Install the GitHub App only on this repository.
CONTENT_GITHUB_OWNER=kommiter
CONTENT_GITHUB_REPO=coderoot-content
CONTENT_GITHUB_DEFAULT_BRANCH=main

# Comma-separated GitHub usernames allowed to save through the extension.
CODEROOT_ALLOWED_GITHUB_LOGINS=kommiter

CODEROOT_PUBLIC_ORIGIN=https://www.codetree.ai

# Generate one with: openssl rand -base64 32
CODEROOT_SESSION_SECRET=replace-with-at-least-32-random-characters
